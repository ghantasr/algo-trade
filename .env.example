# Copy this file to .env and fill in your values:
#   cp .env.example .env

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── NSE Intraday Advisory (no watchlist needed) ──

# ₹ per stock suggestion
INVESTMENT_PER_TRADE=10000

# Profit target after broker fees (%)
TARGET_PROFIT_PCT=5
MAX_PROFIT_PCT=10

# Sell if loss exceeds this % after fees
STOP_LOSS_PCT=2

# Exit all positions this many minutes before NSE close (3:30 PM)
EXIT_MINUTES_BEFORE_CLOSE=60

# Scan every N seconds (120 = 2 min)
CHECK_INTERVAL=120

# Max stocks in bucket at once
MAX_POSITIONS=3

# Min % gain today before suggesting buy (stock must already be moving up)
MIN_GAIN_PCT=0.5

# Candle size for momentum analysis
INTERVAL=5m
SHORT_MA=9
LONG_MA=21
